# ─── Vision API Connection ────────────────────────────────────────────────────
# Qwen DashScope (cloud, recommended):
OLLAMA_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OLLAMA_MODEL=qwen-vl-max

# Local Ollama (alternative):
# OLLAMA_API_BASE=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5vl:7b

# ─── API Key ──────────────────────────────────────────────────────────────────
# Required for cloud APIs (Qwen DashScope, OpenAI, etc.)
# Leave as "ollama" for local Ollama (no auth required)
OLLAMA_API_KEY=sk-your-key-here
