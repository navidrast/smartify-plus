# ─── Ollama Connection ────────────────────────────────────────────────────────
# For local Ollama:    http://localhost:11434/v1
# For docker-compose:  http://ollama:11434/v1   (use the service name)
# For hosted Ollama:   https://your-ollama-host.example.com/v1
OLLAMA_API_BASE=http://localhost:11434/v1

# ─── Model Selection ──────────────────────────────────────────────────────────
# Primary: qwen2.5vl:7b  (best accuracy, ~6 GB VRAM)
# Lighter:  qwen2.5vl:3b  (faster on CPU, slightly lower accuracy)
OLLAMA_MODEL=qwen2.5vl:7b
